# GitHub Brain — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# GitHub personal access token (classic)
# Required scope: public_repo
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Activeloop account token
# Get from: https://app.activeloop.ai
ACTIVELOOP_TOKEN=

# Activeloop organization/username
# This is the org ID in your Deep Lake dataset path: hub://ORG/github_brain
ACTIVELOOP_ORG=

# Gemini API key
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
