# GitHub Brain — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# GitHub personal access token (classic)
# Required scope: public_repo
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Activeloop account token
# Get from: https://app.activeloop.ai
ACTIVELOOP_TOKEN=

# Activeloop organization/username
# This is the org ID in your Deep Lake dataset path: hub://ORG/github_brain
ACTIVELOOP_ORG=

# GCP service account JSON (full JSON as a single line, not a file path)
# To flatten your key file in PowerShell:
#   (Get-Content "path\to\key.json" -Raw) -replace "`r`n|`n|`r", "" | Set-Clipboard
# Then paste the result after the = below
GCP_SERVICE_ACCOUNT_JSON=

# Vertex AI region (us-central1 works for most accounts)
GOOGLE_CLOUD_LOCATION=us-central1
